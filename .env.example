# Network Monitor 環境變數設定

# Flask 密鑰 (生產環境請務必更改)
SECRET_KEY=your-secret-key-change-in-production

# MySQL 連接設定
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=netmonitor
MYSQL_PASSWORD=netmonitor123
MYSQL_DATABASE=netmonitor

# Ping 設定
PING_INTERVAL_SECONDS=60    # Ping 間隔秒數
PING_COUNT=4                # 每次 Ping 次數
PING_TIMEOUT=2              # Ping 超時秒數

# 預設管理員帳號 (首次啟動時建立)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
